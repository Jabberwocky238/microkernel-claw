{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@openintern": ["src/index.ts"],
      "@openintern/kernel": ["src/kernel/index.ts"],
      "@openintern/kernel/*": ["src/kernel/*.ts"],
      "@openintern/service": ["src/service/index.ts"],
      "@openintern/service/*": ["src/service/*.ts"],
      "@openintern3/plugin-agent": ["plugins/agent/src/index.ts"],
      "@openintern3/plugin-agent/*": ["plugins/agent/src/*.ts"]
    },
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2020"],
    "skipLibCheck": true
  },
  "include": [
    "src",
    "plugins/agent",
    "plugins/cron",
    "plugins/echo",
    "plugins/feishu",
    "plugins/filesystem",
    "plugins/telegram",
    "plugins/terminals",
    "plugins/whatsapp",
    "plugins/wecom"
  ]
}
